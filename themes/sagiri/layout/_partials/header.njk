<nav class="site-nav">
  {% set header_light_webp = url_for('/images/header-weathering-with-you.webp') %}
  {% set header_light_png = url_for('/images/header-weathering-with-you.png') %}
  {% set header_dark_jpg = url_for('/images/header-dark-mode.jpg') %}
  {% set avatar_dark_src = url_for('/images/avatar-dark-mode.webp') %}
  {% if theme.menu %}
    <ul id="menu" class="menu">
      {% for name, path in theme.menu %}
        {% set itemName = name.toLowerCase() %}
        <li class="menu-item menu-item-{{ itemName | replace(' ', '-') }}">
          <a href="{{ url_for(trim(path.split('||')[0])) }}" rel="section"{% if path.split('||')[2] %} target="_blank"{% endif %}>
            {% if theme.menu_icons.enable %}
              <i class="menu-item-icon {{ trim(path.split('||')[1]) }}"></i> <br />
            {% endif %}
            {{ __('menu.' + name) | replace('menu.', '') }}
          </a>
          {% if theme.submenu[itemName] %}
            <ul class="submenu submenu-{{ itemName | replace(' ', '-') }}">
              {% for name, path in theme.submenu[itemName] %}
                {% set itemName = name | lower %}
                <li class="submenu-item submenu-item-{{ itemName | replace(' ', '-') }}">
                  <a href="{{ trim(url_for(path)) }}" rel="section" target="_blank">
                    {{ __('menu.' + name) | replace('menu.', '') }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}

      <li class="menu-item menu-item-dark-mode">
        <a
          href="#"
          rel="section"
          onclick="enableDarkTheme(); return false;"
          aria-label="Enable dark theme"
        >
          {% if theme.menu_icons.enable %}
            <i class="menu-item-icon fas fa-moon"></i> <br />
          {% endif %}
          DarkTheme
        </a>
      </li>

      <li class="menu-item search">
          <form class="search-form">
            <input name="keyword" type="text" class="search-input" placeholder="Search website">
            <button type="submit" class="search-submit"><i class="fas fa-search"></i></button>
          </form>
      </li>
    </ul>
  {% endif %}
</nav>

<div class="site-brand-wrapper">
  <div class="site-brand-bg">
    <picture>
      <source
        id="header-brand-source-webp"
        srcset="{{ header_light_webp }}"
        data-light-srcset="{{ header_light_webp }}"
        data-light-type="image/webp"
        data-dark-srcset="{{ header_dark_jpg }}"
        data-dark-type="image/jpeg"
        type="image/webp"
        media="(max-width: 500px)"
      >
      <source
        id="header-brand-source-fallback"
        srcset="{{ header_light_png }}"
        data-light-srcset="{{ header_light_png }}"
        data-light-type="image/png"
        data-dark-srcset="{{ header_dark_jpg }}"
        data-dark-type="image/jpeg"
        type="image/png"
        media="(max-width: 500px)"
      >
      <img
        id="header-brand-image"
        loading="lazy"
        src="{{ header_light_png }}"
        data-light-src="{{ header_light_png }}"
        data-dark-src="{{ header_dark_jpg }}"
      >
    </picture>
  </div>
  <div class="site-meta ">
    <div class="custom-logo-site-title">
      <div class="brand">
        <span class="logo-line-before"><i></i></span>
        <div class="site-title">
          <div id="animate-stroke" class="animate">
            {% for letter in config.title %}{#
              #}<span>
                  <svg>
                    <use xlink:href="#stroke{{ letter }}"></use>
                  </svg>
                </span>{#
            #}{% endfor %}
          </div>
          <div id="animate" class="animate">
            {% for letter in config.title %}{#
              #}<span>
                  <svg>
                    <text id="stroke{{ letter }}">{{ letter }}</text>
                  </svg>
                </span>{#
            #}{% endfor %}
          </div>
          <div id="guide" class="guide">
            {% for letter in config.title %}{#
              #}<span>{{ letter }}</span>{#
            #}{% endfor %}
          </div>
        </div>
        <span class="logo-line-after"><i></i></span>
      </div>
    </div>
      {% if theme.seo %}
        <h1 class="site-subtitle" itemprop="description">{{ config.subtitle }}</h1>
      {% else %}
        <p class="site-subtitle">{{ config.subtitle }}</p>
      {% endif %}
  </div>

  <div class="site-nav-toggle">
    <button>
      <span class="btn-bar"></span>
      <span class="btn-bar"></span>
      <span class="btn-bar"></span>
    </button>
  </div>
</div>
<div class="site-master" itemprop="author" itemscope itemtype="http://schema.org/Person">
    {% set _avatar_src = theme.avatar if theme.avatar else theme.images + '/avatar.gif' %}
  <img
    id="site-master-avatar"
    class="site-master-avatar scaleup"
    itemprop="image"
    src="{{ url_for(_avatar_src) }}"
    data-light-src="{{ url_for(_avatar_src) }}"
    data-dark-src="{{ avatar_dark_src }}"
    alt="{{ theme.author }}"
  />
    <h2 class="site-master-description scaleup" itemprop="description">
        {{ theme.description }}
    </h2>
</div>
